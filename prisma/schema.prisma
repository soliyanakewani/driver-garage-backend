// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  DRIVER
  GARAGE
}

enum AccountStatus {
  ACTIVE
  PENDING
  REJECTED
  BLOCKED
  WARNED
}

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notifications AdminNotification[]
}

model Driver {
  id           String        @id @default(uuid())
  firstName    String
  lastName     String
  email        String        @unique
  phone        String        @unique
  password     String
  isPhoneVerified Boolean    @default(false)
  isEmailVerified Boolean    @default(false)
  status       AccountStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  vehicles     Vehicle[]
  maintenanceReminders MaintenanceReminder[]
  maintenanceRecords   MaintenanceRecord[]
  notifications        DriverNotification[]
  garageRatings        GarageRating[]
  posts                Post[]
  postLikes            PostLike[]
  postComments         PostComment[]
  postBookmarks        PostBookmark[]
  postReports          PostReport[]
}

model Vehicle {
  id                     String    @id @default(uuid())
  driverId               String
  plateNumber             String
  make                    String
  model                   String
  type                    String?   // e.g. sedan, SUV
  year                    Int
  color                   String?
  vin                     String?   @db.VarChar(17)
  mileage                 Int?      // current mileage in miles
  fuelType                String?   @map("fuel_type")
  imageUrl                String?   @map("image_url")
  insuranceDocumentUrl    String?   @map("insurance_document_url")
  insuranceExpiresAt      DateTime? @map("insurance_expires_at")
  registrationDocumentUrl String?   @map("registration_document_url")
  registrationExpiresAt   DateTime? @map("registration_expires_at")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  driver                  Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  appointments            Appointment[]
  maintenanceReminders    MaintenanceReminder[]
  maintenanceRecords      MaintenanceRecord[]
  maintenanceHealth       VehicleMaintenanceHealth?
  driverNotifications     DriverNotification[]

  @@unique([driverId, plateNumber])
  @@index([driverId])
}

model Garage {
  id               String                @id @default(uuid())
  name             String
  email            String                @unique
  phone            String                @unique
  password         String
  isPhoneVerified Boolean               @default(false)
  isEmailVerified Boolean               @default(false)
  status           AccountStatus         @default(PENDING)
  address          String?
  latitude         Float?
  longitude        Float?
  /// Business / registration document (PDF or image URL); signup or profile update
  businessDocumentUrl String?            @map("business_document_url")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  appointments     Appointment[]
  availabilitySlots GarageAvailabilitySlot[]
  services         GarageService[]
  notifications    GarageNotification[]
  setting          GarageSetting?
  ratings          GarageRating[]
}

/// Email OTP for garage signup (before a Garage row exists). One row per email.
model GarageSignupOtp {
  id         String    @id @default(uuid())
  email      String    @unique
  codeHash   String
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model GarageNotification {
  id        String   @id @default(uuid())
  garageId  String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([garageId])
}

model GarageSetting {
  id        String   @id @default(uuid())
  garageId  String   @unique
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt

  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
}

model GarageRating {
  id        String   @id @default(uuid())
  garageId  String
  driverId  String
  appointmentId String? @unique
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([garageId])
  @@index([driverId])
}

model GarageService {
  id        String   @id @default(uuid())
  garageId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
  appointmentServices AppointmentService[]

  @@index([garageId])
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model GarageAvailabilitySlot {
  id          String    @id @default(uuid())
  garageId    String
  dayOfWeek   DayOfWeek
  startMinute Int
  endMinute   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  garage      Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([garageId, dayOfWeek])
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  IN_SERVICE
  COMPLETED
  CANCELLED
}

model Appointment {
  id                 String            @id @default(uuid())
  driverId           String
  garageId           String
  vehicleId          String?
  scheduledAt        DateTime
  serviceDescription String
  status             AppointmentStatus @default(PENDING)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  driver             Driver            @relation(fields: [driverId], references: [id], onDelete: Cascade)
  garage             Garage            @relation(fields: [garageId], references: [id], onDelete: Cascade)
  vehicle            Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  appointmentServices AppointmentService[]
  ratings            GarageRating[]

  @@index([driverId, scheduledAt])
  @@index([garageId, scheduledAt])
}

model AppointmentService {
  id             String      @id @default(uuid())
  appointmentId  String
  garageServiceId String
  createdAt      DateTime    @default(now())
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  garageService  GarageService @relation(fields: [garageServiceId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, garageServiceId])
  @@index([appointmentId])
  @@index([garageServiceId])
}

model DriverNotification {
  id           String   @id @default(uuid())
  driverId     String
  vehicleId    String?
  reminderId   String?
  vehiclePlate String?
  title        String
  body         String
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())

  driver  Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([driverId])
  @@index([vehicleId])
  @@index([reminderId])
}

model AdminNotification {
  id        String   @id @default(uuid())
  adminId   String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model VehicleMaintenanceHealth {
  vehicleId String   @id
  health    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

enum MaintenancePresetCategory {
  OIL_CHANGE
  TIRE_ROTATION
  TIRE_INSPECTION
  BRAKE_INSPECTION
  BRAKE_SERVICE
  BATTERY_CHECK
  COOLANT
  TRANSMISSION_FLUID
  AIR_FILTER
  CABIN_FILTER
  ENGINE_DIAGNOSTIC
  BELTS_HOSES
  SPARK_PLUGS
  WIPERS_LIGHTS
  FLUIDS_CHECK
  OTHER
}

enum EducationCategory {
  ALL
  SAFETY
  MAINTENANCE
  REPAIRS
  TIPS
  MANUALS
}

model EducationContent {
  id          String            @id @default(uuid())
  title       String
  description String
  category    EducationCategory
  imageUrl    String?
  /// PDF document URL for MANUALS category (uploaded by admin)
  pdfUrl      String?           @map("pdf_url")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Post {
  id        String   @id @default(uuid())
  /// Optional display headline; search matches title + content (typical social apps index body text and optional title).
  title     String?
  content   String
  imageUrl  String?
  imageUrls String[] @default([])
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    Driver   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     PostLike[]
  comments  PostComment[]
  bookmarks PostBookmark[]
  reports   PostReport[]

  @@index([authorId])
  @@index([createdAt])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  driverId  String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([postId, driverId])
  @@index([driverId])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  driverId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([driverId])
}

model PostBookmark {
  id        String   @id @default(uuid())
  postId    String
  driverId  String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([postId, driverId])
  @@index([driverId])
}

model PostReport {
  id          String   @id @default(uuid())
  postId       String
  reporterId   String
  reason       String
  details      String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter     Driver   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([postId, reporterId])
  @@index([reporterId])
  @@index([status])
}

model MaintenanceReminder {
  id                    String                   @id @default(uuid())
  driverId              String
  vehicleId             String?
  serviceName           String
  presetCategory        MaintenancePresetCategory?
  customServiceName     String?
  scheduledDate         DateTime
  estimatedCostMin      Float?                   @map("estimated_cost_min")
  estimatedCostMax      Float?                   @map("estimated_cost_max")
  reminderSet           Boolean                  @default(false) @map("reminder_set")
  notifiedAt            DateTime?                @map("notified_at")
  notes                 String?
  completedAt           DateTime?
  healthComponentKey    String?
  healthValueBefore     Float?
  healthReductionApplied Float?
  customSlotId          String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  driver  Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([driverId])
  @@index([vehicleId, scheduledDate])
}

model MaintenanceRecord {
  id          String   @id @default(uuid())
  driverId    String
  vehicleId   String?
  serviceName String
  garageName  String?  @map("garage_name")
  serviceDate DateTime @map("service_date")
  cost        Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  driver  Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([driverId])
}

