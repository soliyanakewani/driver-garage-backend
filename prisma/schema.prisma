// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DRIVER
  GARAGE
}

enum AccountStatus {
  ACTIVE
  PENDING
  REJECTED
  BLOCKED
  WARNED
}

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Driver {
  id           String        @id @default(uuid())
  firstName    String
  lastName     String
  email        String        @unique
  phone        String        @unique
  password     String
  status       AccountStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  vehicles  Vehicle[]
}

model Vehicle {
  id                     String    @id @default(uuid())
  driverId               String
  plateNumber             String
  make                    String
  model                   String
  type                    String?   // e.g. sedan, SUV
  year                    Int
  color                   String?
  vin                     String?   @db.VarChar(17)
  mileage                 Int?      // current mileage in miles
  fuelType                String?   @map("fuel_type")
  imageUrl                String?   @map("image_url")
  insuranceDocumentUrl    String?   @map("insurance_document_url")
  insuranceExpiresAt      DateTime? @map("insurance_expires_at")
  registrationDocumentUrl String?   @map("registration_document_url")
  registrationExpiresAt   DateTime? @map("registration_expires_at")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  driver                  Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  appointments            Appointment[]

  @@unique([driverId, plateNumber])
  @@index([driverId])
}

model Garage {
  id               String                @id @default(uuid())
  name             String
  email            String                @unique
  phone            String                @unique
  password         String
  status           AccountStatus         @default(PENDING)
  address          String?
  latitude         Float?
  longitude        Float?
  /// Business / registration document (PDF or image URL); signup or profile update
  businessDocumentUrl String?            @map("business_document_url")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  appointments     Appointment[]
  availabilitySlots GarageAvailabilitySlot[]
  services         GarageService[]
  notifications    GarageNotification[]
  setting          GarageSetting?
  ratings          GarageRating[]
}

model GarageNotification {
  id        String   @id @default(uuid())
  garageId  String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([garageId])
}

model GarageSetting {
  id        String   @id @default(uuid())
  garageId  String   @unique
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt

  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)
}

model GarageRating {
  id        String   @id @default(uuid())
  garageId  String
  driverId  String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([garageId])
}

model GarageService {
  id        String   @id @default(uuid())
  garageId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  garage    Garage   @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([garageId])
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model GarageAvailabilitySlot {
  id          String    @id @default(uuid())
  garageId    String
  dayOfWeek   DayOfWeek
  startMinute Int
  endMinute   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  garage      Garage    @relation(fields: [garageId], references: [id], onDelete: Cascade)

  @@index([garageId, dayOfWeek])
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  IN_SERVICE
  COMPLETED
  CANCELLED
}

model Appointment {
  id                 String            @id @default(uuid())
  driverId           String
  garageId           String
  vehicleId          String?
  scheduledAt        DateTime
  serviceDescription String
  status             AppointmentStatus @default(PENDING)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  driver             Driver            @relation(fields: [driverId], references: [id], onDelete: Cascade)
  garage             Garage            @relation(fields: [garageId], references: [id], onDelete: Cascade)
  vehicle            Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
}

enum EducationCategory {
  ALL
  SAFETY
  MAINTENANCE
  REPAIRS
  TIPS
}

model EducationContent {
  id          String            @id @default(uuid())
  title       String
  description String
  category    EducationCategory
  imageUrl    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

